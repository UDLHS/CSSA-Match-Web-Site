# ============================================================
# CSSA Cricket Fiesta '26 — environment variables
# Copy to .env and fill in from your Supabase project:
#   Dashboard → Connect (top bar) → ORMs → Prisma   (connection strings)
#   Dashboard → Project Settings → API Keys         (publishable + secret keys)
# ============================================================

# --- Prisma / Postgres (Supabase) ---
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
# Serverless (Vercel) REQUIRES the pooled string with pgbouncer=true.
# connection_limit=10 lets one request fan out parallel reads (RSC Promise.all)
# without exhausting the pool; pool_timeout covers high-latency regions.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20"

# Direct connection (port 5432) — used ONLY by Prisma migrations.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"

# --- Supabase (Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# New-style publishable key (replaces the legacy anon key — safe for the client)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-only secret key (sb_secret_..., replaces legacy service_role).
# NEVER expose to the client or commit a real value.
SUPABASE_SECRET_KEY="sb_secret_..."

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
